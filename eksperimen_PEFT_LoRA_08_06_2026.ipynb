        "tags = np.unique(df['label'])\n",
        "num_labels = len(tags)\n",
        "max_length = 128\n",
        "label2id = {t: i for i, t in enumerate(tags)}\n",
        "id2label = {i: t for i, t in enumerate(tags)}"
