        "def show_log_history(trainer):\n",
        "    log_history = pd.DataFrame(trainer.state.log_history)\n",
        "    log_history = log_history.fillna(0)\n",
        "    log_history = log_history.groupby([\"epoch\"]).sum()\n",
        "\n",
        "    log_history[[\"loss\", \"eval_loss\"]].plot()\n",
        "    plt.show()"
      ],
